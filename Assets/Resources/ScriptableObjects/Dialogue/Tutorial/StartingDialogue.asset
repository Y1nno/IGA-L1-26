  m_Script: {fileID: 11500000, guid: 9e9fc2262e35fe24e9c3cac560837599, type: 3}
  m_Name: StartingDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  dialogueLines:
  - speaker: 0
    line: "Well. Look what my little mousetrap caught. Come in, ch\xE9rie, get to
      work. See if you can prove yourself in my kitchen."
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
  - speaker: 0
    line: ...Make me sweat.
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: 0, y: 0}
    scale: {x: 1, y: 1}
  - speaker: 1
    line: What do I do?
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: 0, y: 0}
    scale: {x: 1, y: 1}
  - speaker: 0
    line: Pick up the knife.
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: 0, y: 0}
    scale: {x: 1, y: 1}
  OnDialogueEnd:
    m_PersistentCalls:
      m_Calls: []
