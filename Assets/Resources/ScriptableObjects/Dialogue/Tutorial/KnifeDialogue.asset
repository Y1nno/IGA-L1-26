  m_Name: KnifeDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  dialogueLines:
  - speaker: 0
    line: "Oh, don\u2019t worry, darling. Nothing like that. I have other plans for
      you..."
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
  - speaker: 0
    line: "Slice this. Nice and even, now, it\u2019s for a human burger \u2014 a
      simple but favorite sandwich at D'Vour\u2019s Devilish Delights. Surely a little
      rat like you can handle that."
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: 0, y: 0}
    scale: {x: 1, y: 1}
