  m_Script: {fileID: 11500000, guid: 9e9fc2262e35fe24e9c3cac560837599, type: 3}
  m_Name: AffectionChangeDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  dialogueLines:
  - speaker: 0
    line: Continue to please me in such ways, and perhaps you can gain my approval.
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
  - speaker: 0
    line: "Displease me\u2026and you\u2019ll find this job very difficult."
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
  - speaker: 0
    line: "Don\u2019t worry, mon chou, I won\u2019t fire you immediately for a mistake\u2026even
      though you deserve it."
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
  - speaker: 0
    line: "But the more mistakes you make on an order, the worse the outcome will
      be for you. Don\u2019t disappoint me."
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
  OnDialogueEnd:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 0}
        m_TargetAssemblyTypeName: 
        m_MethodName: 
        m_Mode: 0
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: 
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: 
          m_BoolArgument: 0
        m_CallState: 2
