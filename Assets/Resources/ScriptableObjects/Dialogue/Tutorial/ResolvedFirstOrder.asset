  dialogueLines:
  - speaker: 0
    line: " Deliciously executed, ch\xE9rie. The patron loved the dish \u2014 *pleased
      w/ hand up* mmm, the way she savored it\u2026"
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
  - speaker: 0
    line: "Perhaps you will be of some use after all \u2014 but don\u2019t let it
      get to your head. Keep prepping my recipes. I\u2019ll be watching\u2026"
    image: {fileID: 1808409080906380215, guid: c58c7139830f4d742aa1680b58fe5cbf, type: 3}
    position: {x: -1.95, y: -1.38}
    scale: {x: 0.4078, y: 0.4078}
